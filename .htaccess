DirectoryIndex index.php

RewriteEngine On

# Pretty URL for admin
RewriteRule ^admin$ views/admin/login.php [L]
RewriteRule ^dashboard$ views/admin/dashboard.php [L]

# --- SEGURIDAD ---

# Prevent directory listing
Options -Indexes

# Block access to specific directories
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(config|models|controllers|api/internal|vendor|node_modules|scratch)/.*$ - [F,L]
    RewriteRule ^database\.sql$ - [F,L]
    RewriteRule ^\.gitignore$ - [F,L]
    RewriteRule ^composer\.(json|lock)$ - [F,L]
    RewriteRule ^package(-lock)?\.json$ - [F,L]
    RewriteRule ^README\.md$ - [F,L]
</IfModule>

# Block access to sensitive file extensions
<FilesMatch "\.(sql|env|ini|log|sh|inc|bak|swp|md)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
